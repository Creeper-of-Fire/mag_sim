# .env.warpx - 等离子体模拟工具的中央配置文件
# 此文件存储路径和设置，以避免在脚本中硬编码。

# --- 项目路径 (WSL 内的绝对路径) ---
PROJECT_ROOT_WSL="/mnt/warpx/mag_sim"

# --- 模拟的Conda 配置 ---
CONDA_INIT_PATH="/home/cof/miniconda3/etc/profile.d/conda.sh"
CONDA_ENV_NAME="warpx_env"

# --- Spack 配置 ---
SPACK_ROOT="/root/spack"
SPACK_ENV_NAME="warpx-4090"